<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============ OCEANIC PROFESSIONAL - LIGHT ============ -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#3B82F6</item>
        <item name="colorPrimaryDark">#2563EB</item>
        <item name="colorAccent">#10B981</item>
        <item name="android:textColorPrimary">#1E293B</item>
        <item name="android:textColorSecondary">#64748B</item>
        <item name="android:windowBackground">#F8FAFC</item>
    </style>

    <!-- ============ OCEANIC PROFESSIONAL - DARK ============ -->
    <style name="AppTheme.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">#60A5FA</item>
        <item name="colorPrimaryDark">#0F172A</item>
        <item name="colorAccent">#34D399</item>
        <item name="android:textColorPrimary">#F1F5F9</item>
        <item name="android:textColorSecondary">#94A3B8</item>
        <item name="android:windowBackground">#0F172A</item>
    </style>

    <style name="AppTheme.Alarm" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#EF4444</item>
        <item name="colorAccent">#3B82F6</item>
        <item name="android:windowBackground">#F8FAFC</item>
    </style>

    <!-- ============ CARD ============ -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <!-- ============ TEXT ============ -->
    <style name="ZmanTimeText">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="ZmanLabelText">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?android:textColorPrimary</item>
    </style>
    <style name="ClockText">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="HebrewDateText">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">?android:textColorSecondary</item>
    </style>
    <style name="SectionHeader">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#64748B</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:paddingStart">12dp</item>
    </style>

    <!-- ============ BUTTONS ============ -->
    <style name="ButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">15sp</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="SmallButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textSize">14sp</item>
        <item name="android:minHeight">40dp</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="PillButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">100dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="FocusableItem">
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">false</item>
        <item name="android:background">@drawable/focus_highlight</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="AboutHeaderText">
        <item name="android:textSize">26sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?colorPrimary</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="AboutSubText">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?android:textColorSecondary</item>
        <item name="android:gravity">center</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>
</resources>

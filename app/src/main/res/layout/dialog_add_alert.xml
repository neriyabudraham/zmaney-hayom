<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_zman"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_light"
            android:paddingBottom="6dp" />

        <Spinner
            android:id="@+id/spinner_zman"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:popupBackground="@color/white"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/offset_type"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_light"
            android:paddingTop="12dp"
            android:paddingBottom="6dp" />

        <Spinner
            android:id="@+id/spinner_offset_type"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:popupBackground="@color/white"
            android:padding="8dp" />

        <TextView
            android:id="@+id/offset_value_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/offset_value"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_light"
            android:paddingTop="12dp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/edit_offset_value"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:hint="0"
            android:textSize="15sp"
            android:textColor="@color/text_primary_light"
            android:background="@drawable/edit_text_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <CheckBox
            android:id="@+id/check_sound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sound"
            android:checked="true"
            android:textSize="14sp"
            android:textColor="@color/text_primary_light"
            android:minHeight="44dp"
            android:paddingTop="4dp" />

        <CheckBox
            android:id="@+id/check_vibrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vibrate"
            android:checked="true"
            android:textSize="14sp"
            android:textColor="@color/text_primary_light"
            android:minHeight="44dp" />
    </LinearLayout>
</ScrollView>

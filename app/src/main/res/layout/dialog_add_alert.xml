<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_zman"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_light"
            android:paddingBottom="6dp" />

        <Spinner
            android:id="@+id/spinner_zman"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:background="@drawable/spinner_bg"
            android:popupBackground="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/offset_type"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_light"
            android:paddingTop="12dp"
            android:paddingBottom="6dp" />

        <Spinner
            android:id="@+id/spinner_offset_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:background="@drawable/spinner_bg"
            android:popupBackground="@color/white" />

        <TextView
            android:id="@+id/offset_value_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/offset_value"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_light"
            android:paddingTop="12dp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/edit_offset_value"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="number"
            android:hint="0"
            android:textSize="15sp"
            android:textColor="@color/text_primary_light"
            android:background="@drawable/edit_text_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- Days of week -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ימים פעילים"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_light"
            android:paddingTop="14dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layoutDirection="ltr">

            <CheckBox
                android:id="@+id/day_sun"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="א"
                android:textSize="13sp"
                android:checked="true"
                android:gravity="center"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/text_primary_light" />

            <CheckBox
                android:id="@+id/day_mon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ב"
                android:textSize="13sp"
                android:checked="true"
                android:gravity="center"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/text_primary_light" />

            <CheckBox
                android:id="@+id/day_tue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ג"
                android:textSize="13sp"
                android:checked="true"
                android:gravity="center"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/text_primary_light" />

            <CheckBox
                android:id="@+id/day_wed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ד"
                android:textSize="13sp"
                android:checked="true"
                android:gravity="center"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/text_primary_light" />

            <CheckBox
                android:id="@+id/day_thu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ה"
                android:textSize="13sp"
                android:checked="true"
                android:gravity="center"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/text_primary_light" />

            <CheckBox
                android:id="@+id/day_fri"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ו"
                android:textSize="13sp"
                android:checked="true"
                android:gravity="center"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/text_primary_light" />

            <CheckBox
                android:id="@+id/day_sat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ש"
                android:textSize="13sp"
                android:checked="true"
                android:gravity="center"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:textColor="@color/text_primary_light" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp">

            <TextView
                android:id="@+id/preset_all_days"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="כל הימים"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:gravity="center"
                android:padding="6dp"
                android:background="?android:selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/preset_weekdays"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="א׳-ה׳"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:gravity="center"
                android:padding="6dp"
                android:background="?android:selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/preset_sun_fri"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="א׳-ו׳"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:gravity="center"
                android:padding="6dp"
                android:background="?android:selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/check_sound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sound"
            android:checked="true"
            android:textSize="14sp"
            android:textColor="@color/text_primary_light"
            android:minHeight="44dp"
            android:paddingTop="8dp" />

        <CheckBox
            android:id="@+id/check_vibrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vibrate"
            android:checked="true"
            android:textSize="14sp"
            android:textColor="@color/text_primary_light"
            android:minHeight="44dp" />
    </LinearLayout>
</ScrollView>

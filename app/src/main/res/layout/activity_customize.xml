<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:windowBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/toolbar_bg"
        app:titleTextColor="@color/white"
        app:title="@string/customize"
        app:navigationIcon="?homeAsUpIndicator"
        app:titleTextAppearance="@style/ZmanLabelText" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Ringtone Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ringtone"
                style="@style/SectionHeader" />

            <LinearLayout
                android:id="@+id/row_ringtone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:minHeight="52dp"
                android:background="@drawable/focus_highlight"
                android:focusable="true"
                android:clickable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_ringtone"
                        android:textSize="15sp"
                        android:textColor="?android:textColorPrimary" />

                    <TextView
                        android:id="@+id/txt_current_ringtone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="?android:textColorSecondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Font Size Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/font_size"
                style="@style/SectionHeader"
                android:paddingTop="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="א"
                    android:textSize="22sp"
                    android:textColor="?android:textColorSecondary" />

                <SeekBar
                    android:id="@+id/seekbar_font_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="4"
                    android:progress="2"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layoutDirection="ltr"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="א"
                    android:textSize="12sp"
                    android:textColor="?android:textColorSecondary" />
            </LinearLayout>

            <TextView
                android:id="@+id/font_size_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="טקסט לדוגמה - 14:30"
                android:gravity="center"
                android:padding="8dp"
                android:textSize="14sp"
                android:textColor="?android:textColorPrimary" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>

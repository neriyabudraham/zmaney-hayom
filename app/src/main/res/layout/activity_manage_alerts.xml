<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:windowBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/toolbar_bg"
        app:titleTextColor="@color/white"
        app:title="@string/manage_alerts"
        app:navigationIcon="?homeAsUpIndicator"
        app:titleTextAppearance="@style/ZmanLabelText" />

    <TextView
        android:id="@+id/empty_text"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:text="@string/no_alerts"
        android:gravity="center"
        android:textSize="14sp"
        android:visibility="gone"
        android:textColor="?android:textColorSecondary" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/alerts_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:clipToPadding="false"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="88dp" />

    <!-- Tiny circular add FAB - keyboard accessible -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="הוסף התראה"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:nextFocusUp="@id/alerts_list"
        app:fabSize="mini"
        app:tint="@color/white"
        app:elevation="4dp" />
</RelativeLayout>

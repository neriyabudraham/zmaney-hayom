<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp"
    android:background="?android:windowBackground">

    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- Pulsing alarm icon -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_lock_idle_alarm"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/alarm_zman_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="?colorPrimary"
                android:gravity="center" />

            <TextView
                android:id="@+id/alarm_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="44sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:textColor="@color/alarm_red"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/alarm_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:textColor="?android:textColorSecondary"
                android:layout_marginTop="6dp"
                android:lineSpacingMultiplier="1.4" />

            <TextView
                android:id="@+id/auto_stop_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?android:textColorSecondary"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:text="מפסיק בעוד 60 שניות" />

            <!-- Stop + Snooze side-by-side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center">

                <!-- Snooze button - outlined -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_snooze"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="🛌  נודניק"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    app:cornerRadius="100dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="?colorPrimary"
                    android:textColor="?colorPrimary"
                    android:focusable="true"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- Stop button - solid red, prominent -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_dismiss"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="✋ עצור"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/white"
                    app:cornerRadius="100dp"
                    android:focusable="true"
                    android:backgroundTint="@color/alarm_red"
                    app:elevation="2dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:windowBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/toolbar_bg"
        android:elevation="0dp"
        app:titleTextColor="@color/white"
        app:title="@string/app_name"
        app:titleTextAppearance="@style/ZmanLabelText"
        app:navigationIcon="@drawable/ic_menu_hamburger"
        android:focusable="true" />

    <!-- Compact header: clock+dates+badges+nav buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Day navigation - vertical column on right (in RTL view) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageButton
                android:id="@+id/btn_prev_day"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@android:drawable/ic_media_rew"
                android:background="@drawable/focus_highlight"
                android:scaleType="fitCenter"
                android:padding="6dp"
                android:focusable="true"
                android:contentDescription="יום קודם" />

            <ImageButton
                android:id="@+id/btn_calendar"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:background="@drawable/focus_highlight"
                android:scaleType="fitCenter"
                android:padding="6dp"
                android:focusable="true"
                android:contentDescription="בחר תאריך" />

            <ImageButton
                android:id="@+id/btn_next_day"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@android:drawable/ic_media_ff"
                android:background="@drawable/focus_highlight"
                android:scaleType="fitCenter"
                android:padding="6dp"
                android:focusable="true"
                android:contentDescription="יום הבא" />
        </LinearLayout>

        <!-- Clock + dates + badges, takes remaining space -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp">

            <TextClock
                android:id="@+id/clock_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="34sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:format24Hour="HH:mm:ss"
                android:format12Hour="HH:mm:ss"
                android:textColor="?colorPrimary"
                android:gravity="center" />

            <TextView
                android:id="@+id/hebrew_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="?android:textColorPrimary"
                android:gravity="center" />

            <TextView
                android:id="@+id/gregorian_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?android:textColorSecondary"
                android:gravity="center" />

            <!-- Badges row inside the centered column -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="3dp">

                <LinearLayout
                    android:id="@+id/next_alert_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="gone"
                    android:background="@drawable/badge_accent">

                    <TextView
                        android:id="@+id/next_alert_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?colorPrimary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_today"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="היום"
                    android:textSize="10sp"
                    android:textColor="?colorPrimary"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/badge_accent"
                    android:layout_marginStart="4dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Omer banner full-width below clock when active -->
    <TextView
        android:id="@+id/omer_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="?colorPrimary"
        android:gravity="center"
        android:background="@drawable/badge_accent"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_light" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/zmanim_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:scrollbars="vertical"
        android:overScrollMode="always"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:descendantFocusability="afterDescendants"
        android:nestedScrollingEnabled="true" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Premium gradient toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/toolbar_bg"
        android:elevation="0dp"
        app:titleTextColor="@color/white"
        app:title="@string/app_name"
        app:titleTextAppearance="@style/ZmanLabelText"
        app:navigationIcon="@android:drawable/ic_menu_sort_alphabetically"
        android:focusable="true" />

    <!-- Clock + Date row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Clock with seconds, bold modern -->
        <TextClock
            android:id="@+id/clock_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/ClockText"
            android:format24Hour="HH:mm:ss"
            android:format12Hour="HH:mm:ss"
            android:textColor="@color/primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/gregorian_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/text_secondary_light" />

            <TextView
                android:id="@+id/hebrew_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary_light" />
        </LinearLayout>

        <!-- Next alert badge -->
        <LinearLayout
            android:id="@+id/next_alert_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:background="@drawable/badge_accent">

            <TextView
                android:id="@+id/next_alert_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/primary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Countdown timer bar (hidden by default) -->
    <LinearLayout
        android:id="@+id/countdown_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/highlight_bg"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/countdown_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary_light"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/countdown_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <ImageButton
            android:id="@+id/countdown_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:selectableItemBackgroundBorderless"
            android:layout_marginStart="12dp"
            android:contentDescription="@string/dismiss" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_light" />

    <!-- Zmanim List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/zmanim_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:scrollbars="vertical"
        android:overScrollMode="always"
        android:focusable="true"
        android:nestedScrollingEnabled="true" />

</LinearLayout>

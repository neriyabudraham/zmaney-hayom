<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:windowBackground">

    <!-- Premium gradient toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/toolbar_bg"
        android:elevation="0dp"
        app:titleTextColor="@color/white"
        app:title="@string/app_name"
        app:titleTextAppearance="@style/ZmanLabelText"
        app:navigationIcon="@android:drawable/ic_menu_sort_alphabetically"
        android:focusable="true" />

    <!-- Centered Clock + Hebrew date header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="?attr/colorSurface"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextClock
            android:id="@+id/clock_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="40sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:format24Hour="HH:mm:ss"
            android:format12Hour="HH:mm:ss"
            android:textColor="?colorPrimary"
            android:gravity="center" />

        <TextView
            android:id="@+id/hebrew_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:textColor="?android:textColorPrimary"
            android:gravity="center"
            android:paddingTop="2dp" />

        <TextView
            android:id="@+id/gregorian_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:textColor="?android:textColorSecondary"
            android:gravity="center"
            android:paddingTop="2dp" />

        <LinearLayout
            android:id="@+id/next_alert_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:background="@drawable/badge_accent"
            android:paddingTop="0dp"
            android:layout_marginTop="4dp"
            android:focusable="true">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_lock_idle_alarm"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/next_alert_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?colorPrimary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_light" />

    <!-- Zmanim List - full remaining space -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/zmanim_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:scrollbars="vertical"
        android:overScrollMode="always"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:descendantFocusability="afterDescendants"
        android:nestedScrollingEnabled="true" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:windowBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/toolbar_bg"
        android:elevation="0dp"
        app:titleTextColor="@color/white"
        app:title="@string/app_name"
        app:titleTextAppearance="@style/ZmanLabelText"
        app:navigationIcon="@drawable/ic_menu_hamburger"
        android:focusable="true" />

    <!-- Header row: clock+dates on left (LTR), nav buttons on right (visual right in RTL) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Day navigation grouped (will appear at right side in RTL view) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_prev_day"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_rew"
                android:background="@drawable/focus_highlight"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:focusable="true"
                android:contentDescription="יום קודם" />

            <ImageButton
                android:id="@+id/btn_calendar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:background="@drawable/focus_highlight"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:focusable="true"
                android:contentDescription="בחר תאריך" />

            <ImageButton
                android:id="@+id/btn_next_day"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_ff"
                android:background="@drawable/focus_highlight"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:focusable="true"
                android:contentDescription="יום הבא" />
        </LinearLayout>

        <!-- Clock + dates - takes remaining space, centered -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextClock
                android:id="@+id/clock_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="40sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:format24Hour="HH:mm:ss"
                android:format12Hour="HH:mm:ss"
                android:textColor="?colorPrimary"
                android:gravity="center" />

            <TextView
                android:id="@+id/hebrew_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="?android:textColorPrimary"
                android:gravity="center" />

            <TextView
                android:id="@+id/gregorian_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="?android:textColorSecondary"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- Today button (visible when viewing different day) -->
    <TextView
        android:id="@+id/btn_today"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="חזור להיום"
        android:textSize="12sp"
        android:textColor="?colorPrimary"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/badge_accent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:focusable="true"
        android:clickable="true"
        android:visibility="gone" />

    <!-- Omer + next alert -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/omer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="?colorPrimary"
            android:gravity="center"
            android:background="@drawable/badge_accent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/next_alert_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:background="@drawable/badge_accent"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/next_alert_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?colorPrimary" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_light" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/zmanim_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:scrollbars="vertical"
        android:overScrollMode="always"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:descendantFocusability="afterDescendants"
        android:nestedScrollingEnabled="true" />

</LinearLayout>
